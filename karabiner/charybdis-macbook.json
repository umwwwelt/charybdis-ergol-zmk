{
  "description": "Charybdis MacBook internal keyboard",
  "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "left_option", "modifiers": { "optional": ["any"] } },
          "to_if_alone": [{ "key_code": "escape" }],
          "to_if_held_down": [{ "key_code": "left_shift" }],
          "parameters": {
            "basic.to_if_alone_timeout_milliseconds": 300,
            "basic.to_if_held_down_threshold_milliseconds": 150
          }
        },
        {
          "type": "basic",
          "from": { "key_code": "left_command", "modifiers": { "optional": ["any"] } },
          "to_if_alone": [{ "key_code": "delete_or_backspace" }],
          "to_if_held_down": [{ "set_variable": { "name": "chary_vim_nav", "value": 1 } }],
          "to_after_key_up": [{ "set_variable": { "name": "chary_vim_nav", "value": 0 } }],
          "parameters": {
            "basic.to_if_alone_timeout_milliseconds": 300,
            "basic.to_if_held_down_threshold_milliseconds": 150
          }
        },
        {
          "type": "basic",
          "from": { "key_code": "spacebar", "modifiers": { "optional": ["any"] } },
          "to_if_alone": [{ "key_code": "spacebar" }],
          "to_if_held_down": [{ "set_variable": { "name": "chary_num_row", "value": 1 } }],
          "to_after_key_up": [{ "set_variable": { "name": "chary_num_row", "value": 0 } }],
          "parameters": {
            "basic.to_if_alone_timeout_milliseconds": 300,
            "basic.to_if_held_down_threshold_milliseconds": 150
          }
        },
        {
          "type": "basic",
          "from": { "key_code": "right_command", "modifiers": { "optional": ["any"] } },
          "to_if_alone": [{ "key_code": "return_or_enter" }],
          "to_if_held_down": [{ "set_variable": { "name": "chary_symbols", "value": 1 } }],
          "to_after_key_up": [{ "set_variable": { "name": "chary_symbols", "value": 0 } }],
          "parameters": {
            "basic.to_if_alone_timeout_milliseconds": 300,
            "basic.to_if_held_down_threshold_milliseconds": 150
          }
        },

        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "chary_vim_nav", "value": 1 }], "from": { "key_code": "h", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "left_arrow" }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "chary_vim_nav", "value": 1 }], "from": { "key_code": "j", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "down_arrow" }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "chary_vim_nav", "value": 1 }], "from": { "key_code": "k", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "up_arrow" }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "chary_vim_nav", "value": 1 }], "from": { "key_code": "l", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "right_arrow" }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "chary_vim_nav", "value": 1 }], "from": { "key_code": "y", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "home" }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "chary_vim_nav", "value": 1 }], "from": { "key_code": "u", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "page_down" }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "chary_vim_nav", "value": 1 }], "from": { "key_code": "i", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "page_up" }] },
