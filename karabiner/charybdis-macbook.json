        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "chary_vim_nav", "value": 1 }], "from": { "key_code": "s", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "s", "modifiers": ["left_command"] }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "chary_vim_nav", "value": 1 }], "from": { "key_code": "d", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "tab", "modifiers": ["left_shift", "left_command"] }] },
